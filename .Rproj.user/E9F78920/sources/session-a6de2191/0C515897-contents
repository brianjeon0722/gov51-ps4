us_m_time_series <- read.csv("clean data/us_time_series.csv")
annual <- read.csv("clean data/annual.csv")

```

```{r}

us_y_time_series <- us_m_time_series %>%
  group_by(year) %>%
  summarize(total_relative_score = sum(relative_score)) %>%
  select(year, total_relative_score)

```

```{r}

# Put all datasets into a list and bind them
us_all <- map_dfr(2010:2025, ~ get(paste0("us_", .x)))

```

```{r}

us_combined <- us_all %>%
  left_join(us_y_time_series, by = "year") %>%
  mutate(weighted_score = total_relative_score * prop)

```

```{r}

us_raw <- us_combined %>%
  select(year, state, weighted_score) %>%
  pivot_wider(
    names_from = state,
    values_from = weighted_score,
    names_glue = "{state}_relative_score"
  )

```

```{r}

us_pc <- us_raw %>%
  left_join(annual, by = "year")

us_pc <- us_pc %>%
  mutate(across(
    ends_with("_relative_score"),
    ~ .x / us_pc[[gsub("_relative_score", "", cur_column())]],
    .names = "{.col}_pc"
  ))

us_pc <- us_pc %>%
  select(year, ends_with("_relative_score_pc"))

```

```{r}

us_panel <- us_pc %>%
  pivot_longer(
    cols = ends_with("_relative_score_pc"),
    names_to = "state",
    values_to = "conspiracy_index_pc"
  ) %>%
  mutate(state = gsub("_relative_score_pc", "", state))

state_lookup <- tibble(
  state = c(state.abb, "DC"),
  region = c(as.character(state.region), "South")
)

us_panel <- us_panel %>%
  left_join(state_lookup, by = "state")

```

