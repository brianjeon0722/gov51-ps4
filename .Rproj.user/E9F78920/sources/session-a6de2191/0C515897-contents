## Gini Coefficient

```{r}

acs <- read.csv("clean data/acs.csv")

us_panel <- us_panel %>%
  left_join(acs, join_by("state", "year"))

```

```{r}

us_panel %>%
  ggplot(mapping = aes(x = estimate_gini, y = conspiracy_index_pc)) +
  geom_point() +
  geom_smooth(method = "lm", formula = y ~ x + I(x^2)) +
  labs(y = "Average Conspiracy Index",
       x = "Gini Coefficient") +
  theme_oi()

us_panel %>%
  drop_na(estimate_gini, conspiracy_index_pc) %>%
  mutate(x_bin = cut(estimate_gini, breaks = 20)) %>%
  group_by(x_bin) %>%
  summarise(
    y_mean = mean(conspiracy_index_pc, na.rm = TRUE),
    x_mean = mean(estimate_gini, na.rm = TRUE)
  ) %>%
  ggplot(aes(x = x_mean, y = y_mean)) +
  geom_point() +
  geom_smooth(method = "lm", formula = y ~ x + I(x^2)) +
  labs(y = "Average Conspiracy Index",
       x = "Gini Coefficient") +
  theme_oi()

us_panel %>%
  ggplot(mapping = aes(x = estimate_gini, y = conspiracy_index_pc, color = region)) +
  geom_point() +
  geom_smooth(method = "lm", formula = y ~ x + I(x^2)) +
  labs(y = "Average Conspiracy Index",
       x = "Gini Coefficient") +
  theme_oi()

```

