# Importing CCES Data

```{r}

# cces data for every single year

cces_data <- read_dta("raw data/cces_cumulative.dta")

```



```{r}

library(survey)

cces_clean <- cces_data %>%
  filter(year %in% c(2010:2025)) %>% # for years from 2010-2025
  select(year, state, pid7, weight_cumulative, ideo5) %>%
  # pid 7 = party affiliation (democrat <-> republican)
  # ideo5 = ideological (liberal <-> conservative)
  mutate(
    # Set 8 and 9 to NA, swap 5 and 6
    pid7 = case_when(
      pid7 %in% c(8, 9) ~ NA_real_, # 8 = don't know, 9 = NA
      pid7 == 2 ~ 3, # for some reason, 2 means weakly democrat and 3
      # means democrat. if we want pid7 to be increasingly republican, 
      # the order has to be: strong dem, dem, weak dem, neutral, weak rep
      # rep, strong rep, but the current numbers are in the order:
      # strong dem, weak dem, dem, neutral, rep, weak rep, strong rep, so
      # we flip the numbers
      pid7 == 3 ~ 2,
      pid7 == 5 ~ 6,
      pid7 == 6 ~ 5,
      TRUE ~ as.numeric(pid7)
    ),
    ideo5 = case_when(
      ideo5 == 6 ~ NA_real_,
      TRUE ~ as.numeric(ideo5) # 6 = not sure
    )
  )
         
```

```{r}

# calculate year x state weighted means
state_pid <- cces_clean %>%
  group_by(state, year) %>%
  summarise(
    net_rep   = weighted.mean(pid7 >= 5, weight_cumulative, na.rm = TRUE) -
                weighted.mean(pid7 <= 3, weight_cumulative, na.rm = TRUE),
    mean_pid7 = weighted.mean(pid7, weight_cumulative, na.rm = TRUE),
    mean_ideo5 = weighted.mean(ideo5, weight_cumulative, na.rm = TRUE),
    .groups = "drop"
  )

state_pid <- state_pid %>% # make abbreviations
  mutate(state = fips_codes$state[match(state, as.integer(fips_codes$state_code))])

# export to clean data
write.csv(state_pid, "clean data/cces_clean.csv", row.names = FALSE)

```

