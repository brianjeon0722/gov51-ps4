acs <- map_dfr(years, function(yr) {
  get_acs(
    geography = "state",
    variables = c(
      gini  = "B19083_001", # gini coefficient
      y_pc  = "B19301_001", # income per capita
      total_cit = "B05001_001", # citizens + non citizens
      not_citizen = "B05001_006" # non citizens
    ),
    year = yr,
    survey = "acs1" # all 1 year census surveys
  ) %>% mutate(year = yr)
}) %>%
  pivot_wider(
    names_from = variable,
    values_from = c(estimate, moe)
  ) %>%
  filter(NAME != "Puerto Rico") %>% # exclude puero rico
  mutate(
    state = state.abb[match(NAME, state.name)],
    state = case_when(
      NAME == "District of Columbia" ~ "DC", # state.abb doesn't do DC
      TRUE ~ state
    )
  )

