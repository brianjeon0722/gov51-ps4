# Importing Google Trends Data

```{r}

# function to import all us_[year]_raw.sv data

cross_sectional_files <- list.files("raw data/Google Trends/us_cross_sectional/", 
                                    pattern = "\\.csv$", full.names = TRUE)

start_year <- 2010

for (i in seq_along(cross_sectional_files)) {
  f_cs <- cross_sectional_files[i]
  name_cs <- tools::file_path_sans_ext(basename(f_cs))
  
  df <- read.csv(f_cs, header = FALSE)
  
  # remove first two rows (empty rows)
  df <- df[-c(1, 2), ]
  
  # rename columns
  colnames(df)[1:2] <- c("state", "relative_score")
  
  df$relative_score <- as.numeric(gsub("[^0-9.]", "", df$relative_score))
  
  # change appreviations
  df$state <- trimws(df$state)
  df$state[df$state == "District of Columbia"] <- "DC"
  matched <- match(df$state, state.name)
  df$state[!is.na(matched)] <- state.abb[matched[!is.na(matched)]]
  
  # add year column
  df$year <- start_year + i - 1
  
  # add prop column - this is what % of the total searches was by the state
  # because the current out of 100 numbers are scaled magnitudes, we care
  # more about what % each state is
  # ex: assume only 2 states: CA is 100 and Texas is 50 
  # then we know CA must be 2/3 of the total US searches and Texas is 1/3 
  # of all US searches.
  
  df$prop <- df$relative_score / sum(df$relative_score, na.rm = TRUE)
  
  assign(name_cs, df)
}

rm(df)

```


